APP_ENV=development
API_PORT=8000
WEB_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173
POSTGRES_DB=proxmox_backup_orchestrator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/proxmox_backup_orchestrator
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=proxmox-backup-orchestrator
PVE_API_URL=https://proxmox.example.local:8006/api2/json
PVE_API_TOKEN_ID=root@pam!pbo-api
PVE_API_TOKEN_SECRET=replace-me
PVE_VERIFY_SSL=false
PVE_NODE_NAME=proxmox
PBS_API_URL=https://pbs.example.local:8007/api2/json
PBS_TOKEN_ID=root@pam!pbo-pbs
PBS_TOKEN_SECRET=replace-me
PBS_VERIFY_SSL=false
PBS_FINGERPRINT=
PBS_DATASTORE=backup
HOST_AGENT_COMMAND=python -m agent.main
HOST_AGENT_WORKDIR=
HOST_AGENT_TIMEOUT_SECONDS=7200
AGENT_API_BASE_URL=http://localhost:8000/api/v1
AGENT_HOSTNAME=proxmox-host
AGENT_VERSION=0.1.0
AGENT_TIMEOUT_SECONDS=10
AGENT_INCLUDE_NON_USB_CANDIDATES=false
AGENT_STALE_AFTER_MINUTES=10
AGENT_EXPORT_TIMEOUT_SECONDS=7200
