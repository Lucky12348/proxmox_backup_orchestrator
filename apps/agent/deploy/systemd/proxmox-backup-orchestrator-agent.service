[Unit]
Description=Proxmox Backup Orchestrator host agent sync
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/proxmox-backup-orchestrator-agent
EnvironmentFile=/opt/proxmox-backup-orchestrator-agent/.env
ExecStart=/opt/proxmox-backup-orchestrator-agent/.venv/bin/python -m agent.main sync-state

[Install]
WantedBy=multi-user.target
